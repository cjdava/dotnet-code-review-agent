# Required
OPENAI_API_KEY=your-openai-api-key-here
GITHUB_TOKEN=your-github-token-here

# Optional (defaults shown)
OPENAI_MODEL=gpt-4.1-mini
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30

# Comma-separated list of best-practices checklist URLs.
# Add multiple URLs to layer enterprise, team, and project-level rules.
# Each source is fetched independently and combined into one merged checklist.
BEST_PRACTICES_URLS=https://raw.githubusercontent.com/cjdava/best-practices/main/code-peer-review.md
# Example with multiple sources:
# BEST_PRACTICES_URLS=https://enterprise.example.com/standards.md,https://raw.githubusercontent.com/cjdava/best-practices/main/code-peer-review.md,https://team.example.com/rules.md
